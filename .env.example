# Copy to .env and fill in any repo-specific values you need locally.
# bun auto-loads .env — no dotenv needed.
#
# Codex-based evals use your local Codex CLI auth, not a separate API key.
# Optional: override the LLM-as-judge model used by test:llm-eval / test:evals.
CODEX_JUDGE_MODEL=gpt-5.4-mini
