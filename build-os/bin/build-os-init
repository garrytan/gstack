#!/usr/bin/env bash
# build-os-init: Initialize a new build-os project in the current directory.
# Usage: build-os-init [--name "Project Name"] [--type new_construction|renovation] [--budget 500000]
set -euo pipefail

NAME=""
TYPE=""
BUDGET=""

# Parse flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    --name) NAME="$2"; shift 2 ;;
    --type) TYPE="$2"; shift 2 ;;
    --budget) BUDGET="$2"; shift 2 ;;
    *) echo "Unknown flag: $1"; exit 1 ;;
  esac
done

# Prompt for missing values
if [ -z "$NAME" ]; then
  read -rp "Project name: " NAME
fi
if [ -z "$TYPE" ]; then
  echo "Project type:"
  echo "  1) new_construction"
  echo "  2) renovation"
  read -rp "Choice [1/2]: " _CHOICE
  [[ "$_CHOICE" == "2" ]] && TYPE="renovation" || TYPE="new_construction"
fi
if [ -z "$BUDGET" ]; then
  read -rp "Total budget (numbers only, e.g. 500000): " BUDGET
fi

# Validate
if [ -f ".build-os/config.yaml" ]; then
  echo "⚠  A build-os project already exists here."
  read -rp "Reinitialize? This overwrites config. [y/N]: " _CONFIRM
  [[ "$_CONFIRM" =~ ^[Yy]$ ]] || exit 0
fi

# Compute slug
SLUG=$(echo "$NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | tr -s '-' | sed 's/^-\|-$//g')
DATE=$(date +%Y-%m-%d)

# Phase 1 label by track
if [ "$TYPE" = "renovation" ]; then
  PHASE="1-scope-definition"
  TRACK="renovation"
else
  PHASE="1-concept"
  TRACK="new-construction"
fi

# Create directories
mkdir -p .build-os design "budget/bids" schedule permits "contracts/rfps" "contracts/executed" \
         "construction/site-reports" marketing

# Write config
cat > .build-os/config.yaml << EOF
# build-os project config — generated by build-os-init
name: "${NAME}"
project_type: "${TYPE}"
phase_track: "${TRACK}"
current_phase: "${PHASE}"
budget: ${BUDGET}
location: ""
created: "${DATE}"
slug: "${SLUG}"
EOF

# Write skeleton PROJECT.md
cat > PROJECT.md << EOF
# ${NAME}

**Type:** ${TYPE//_/ } | **Phase:** ${PHASE} | **Budget:** \$$(printf "%'d" $BUDGET)
**Created:** ${DATE}

---

## Program

_Run /kickoff to populate this section._

## Budget Summary

_Run /kickoff to populate this section._

## Schedule

_Run /kickoff to populate this section._

## Open Items

_No open items yet._
EOF

# Initialize global state
mkdir -p "${HOME}/.build-os/projects/${SLUG}"
touch "${HOME}/.build-os/projects/${SLUG}/decisions.jsonl"
touch "${HOME}/.build-os/projects/${SLUG}/learnings.jsonl"

echo ""
echo "✓ build-os project initialized: ${NAME}"
echo "  Config:       .build-os/config.yaml"
echo "  Global state: ~/.build-os/projects/${SLUG}/"
echo ""
echo "Next step: open Claude Code here and run /kickoff to set up the full project brief."
