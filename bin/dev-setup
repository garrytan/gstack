#!/usr/bin/env bash
# Set up gstack for local development — test skills from within this repo.
#
# Creates skills → .gemini/skills symlink so Gemini CLI discovers skills
# from your working tree. Changes take effect immediately.
#
# Also copies .env from the main worktree if this is a git worktree
# (so API keys carry over automatically).
#
# Usage: bin/dev-setup       # set up
#        bin/dev-teardown    # clean up
set -e

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# 1. Copy .env from main worktree (if we're a worktree and don't have one)
if [ ! -f "$REPO_ROOT/.env" ]; then
  MAIN_WORKTREE="$(git -C "$REPO_ROOT" worktree list --porcelain 2>/dev/null | head -1 | sed 's/^worktree //')"
  if [ -n "$MAIN_WORKTREE" ] && [ "$MAIN_WORKTREE" != "$REPO_ROOT" ] && [ -f "$MAIN_WORKTREE/.env" ]; then
    cp "$MAIN_WORKTREE/.env" "$REPO_ROOT/.env"
    echo "Copied .env from main worktree ($MAIN_WORKTREE)"
  fi
fi

# 2. Install dependencies
if [ ! -d "$REPO_ROOT/node_modules" ]; then
  echo "Installing dependencies..."
  (cd "$REPO_ROOT" && bun install)
fi

# 3. Generate Gemini skill docs
echo "Generating Gemini skill docs..."
(cd "$REPO_ROOT" && bun run gen:skill-docs --host gemini)

# 4. Create skills → .gemini/skills symlink
SKILLS_LINK="$REPO_ROOT/skills"
if [ -L "$SKILLS_LINK" ]; then
  echo "Updating existing symlink..."
  rm "$SKILLS_LINK"
fi
if [ ! -e "$SKILLS_LINK" ]; then
  ln -s ".gemini/skills" "$SKILLS_LINK"
fi

# 5. Link as Gemini extension
echo "Link this repo as a Gemini extension:"
echo "  gemini extensions link $REPO_ROOT"

echo ""
echo "Dev mode active. Skills resolve from this working tree."
echo "  skills → .gemini/skills"
echo "Edit any SKILL.md.tmpl, run 'bun run gen:skill-docs --host gemini', and test immediately."
echo ""
echo "To tear down: bin/dev-teardown"
