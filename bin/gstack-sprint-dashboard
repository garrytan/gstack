</div>

<div class="grid">
  <div>
    <h2>Quality scores (last ${HISTORY_WINDOW_DAYS}d)</h2>
    <section>${sections.quality}</section>
  </div>
  <div>
    <h2>Active design docs</h2>
    <section>${sections.designDocs}</section>
  </div>
