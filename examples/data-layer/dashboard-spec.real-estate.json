{
  "id": "real_estate_operator_dashboard",
  "domain": "real_estate",
  "sanitized": true,
  "panels": [
    {
      "title": "GStack/OpenClaw activity",
      "metrics": [
        "skill_runs",
        "hours_saved",
        "acceptance_rate"
      ]
    },
    {
      "title": "Lead funnel",
      "metrics": [
        "new_leads",
        "lead_response_time",
        "showing_rate",
        "offer_rate",
        "closing_rate"
      ]
    },
    {
      "title": "Workflow quality",
      "metrics": [
        "edited_runs",
        "rejected_runs",
        "grounded_review_failures",
        "fair_housing_review_flags"
      ]
    }
  ],
  "export_targets": [
    "csv",
    "json",
    "jsonl",
    "duckdb",
    "sqlite",
    "postgres",
    "supabase",
    "nextjs",
    "streamlit",
    "observable",
    "evidence.dev",
    "metabase",
    "grafana",
    "retool"
  ]
}
