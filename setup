#!/usr/bin/env bash
# research-stack setup — generate skill docs + register skills with Claude Code
set -e

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "  Install: curl -fsSL https://bun.sh/install | bash" >&2
  exit 1
fi

SOURCE_DIR="$(cd "$(dirname "$0")" && pwd -P)"

# ─── Parse flags ──────────────────────────────────────────────
LOCAL_INSTALL=0
while [ $# -gt 0 ]; do
  case "$1" in
    --local) LOCAL_INSTALL=1; shift ;;
    *) shift ;;
  esac
done

# ─── 1. Install dependencies ─────────────────────────────────
echo "Installing dependencies..."
(cd "$SOURCE_DIR" && bun install --frozen-lockfile 2>/dev/null || bun install)

# ─── 2. Generate SKILL.md files from templates ───────────────
echo "Generating skill docs..."
(cd "$SOURCE_DIR" && bun run gen:skill-docs)

# ─── 3. Ensure global state directory ────────────────────────
mkdir -p "$HOME/.gstack/projects"

# ─── 4. Create skill symlinks ────────────────────────────────
if [ "$LOCAL_INSTALL" -eq 1 ]; then
  SKILLS_DIR="$(pwd)/.claude/skills"
else
  SKILLS_DIR="$HOME/.claude/skills"
fi

RSTACK_DIR="$SKILLS_DIR/research-stack"

# Create or update the main symlink
mkdir -p "$SKILLS_DIR"
if [ -L "$RSTACK_DIR" ] || [ ! -e "$RSTACK_DIR" ]; then
  ln -snf "$SOURCE_DIR" "$RSTACK_DIR"
fi

# Create per-skill symlinks
LINKED=()
for skill_dir in "$SOURCE_DIR"/*/; do
  if [ -f "$skill_dir/SKILL.md" ]; then
    skill_name="$(basename "$skill_dir")"
    [ "$skill_name" = "node_modules" ] && continue
    target="$SKILLS_DIR/$skill_name"
    if [ -L "$target" ] || [ ! -e "$target" ]; then
      ln -snf "research-stack/$skill_name" "$target"
      LINKED+=("$skill_name")
    fi
  fi
done

# ─── 5. Done ─────────────────────────────────────────────────
echo ""
echo "research-stack ready!"
echo "  skills dir: $RSTACK_DIR"
if [ ${#LINKED[@]} -gt 0 ]; then
  echo "  linked: ${LINKED[*]}"
fi
echo ""
echo "Available skills:"
echo "  /hypothesis      — structure research ideas into experiment specs"
echo "  /run-experiment  — generate code, review, execute with research log"
echo "  /report          — analyze results, compare baselines, generate plots"
echo ""
if [ "$LOCAL_INSTALL" -eq 1 ]; then
  echo "Installed locally to: $SKILLS_DIR"
else
  echo "Installed globally to: $SKILLS_DIR"
fi
