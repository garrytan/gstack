#!/usr/bin/env bash
# gstack-codex setup — build browser binary and prepare the skill bundle for Codex
set -e

GSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
BUNDLE_DIR="$GSTACK_DIR"
BROWSE_BIN="$BUNDLE_DIR/browse/dist/browse"

ensure_playwright_browser() {
  (
    cd "$BUNDLE_DIR"
    bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
  ) >/dev/null 2>&1
}

# 1. Build browse binary if needed (smart rebuild: stale sources, package.json, lock)
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$BUNDLE_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$BUNDLE_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$BUNDLE_DIR/bun.lock" ] && [ "$BUNDLE_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  echo "Building browse binary..."
  (
    cd "$BUNDLE_DIR"
    bun install
    bun run build
  )
  # Safety net: write .version if build script didn't (e.g., git not available during build)
  if [ ! -f "$BUNDLE_DIR/browse/dist/.version" ]; then
    git -C "$BUNDLE_DIR" rev-parse HEAD > "$BUNDLE_DIR/browse/dist/.version" 2>/dev/null || true
  fi
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "gstack-codex setup failed: browse binary missing at $BROWSE_BIN" >&2
  exit 1
fi

# 2. Ensure Playwright's Chromium is available
if ! ensure_playwright_browser; then
  echo "Installing Playwright Chromium..."
  (
    cd "$BUNDLE_DIR"
    bunx playwright install chromium
  )
fi

if ! ensure_playwright_browser; then
  echo "gstack-codex setup failed: Playwright Chromium could not be launched" >&2
  exit 1
fi

# 3. Ensure ~/.gstack global state directory exists
mkdir -p "$HOME/.gstack/projects"

# 4. Print install guidance for both supported layouts
echo "gstack-codex ready."
echo "  browse: $BROWSE_BIN"
echo "  bundle: $BUNDLE_DIR"
echo "  user install: ~/.codex/skills/gstack-codex"
echo "  vendored install: .codex/skills/gstack-codex"
echo "  note: Codex can load nested skills directly from the bundle root; no per-skill symlinks are required."

# 5. First-time welcome + legacy cleanup
if [ ! -d "$HOME/.gstack" ]; then
  mkdir -p "$HOME/.gstack"
fi
echo "  Upgrade workflow: read gstack-upgrade/SKILL.md when prompted by the update check."
rm -f /tmp/gstack-latest-version
